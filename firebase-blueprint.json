{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A fashion item available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "description": "Category (e.g., Dresses, Knitwear)" },
        "image": { "type": "string", "description": "URL to product image" },
        "description": { "type": "string", "description": "Detailed description" },
        "stock": { "type": "number", "description": "Current inventory count" },
        "isNew": { "type": "boolean", "description": "Whether it's a new arrival" }
      },
      "required": ["name", "price", "category", "image", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the customer" },
        "customerEmail": { "type": "string", "description": "Email of the customer" },
        "items": { 
          "type": "array", 
          "description": "List of items in the order",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "image": { "type": "string" }
            }
          }
        },
        "totalAmount": { "type": "number", "description": "Total order value" },
        "status": { 
          "type": "string", 
          "enum": ["pending", "processing", "shipped", "delivered", "cancelled"],
          "description": "Current fulfillment status"
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order timestamp" },
        "shippingAddress": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "zip": { "type": "string" },
            "country": { "type": "string" }
          }
        }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["email", "role"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for the website content.",
      "type": "object",
      "properties": {
        "heroImage": { "type": "string", "description": "URL for the hero section image" },
        "marqueeItems": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of phrases for the marquee" 
        },
        "footer": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "instagram": { "type": "string" },
            "twitter": { "type": "string" }
          }
        }
      }
    },
    "Address": {
      "title": "Address",
      "description": "A user's saved shipping address.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the owner" },
        "name": { "type": "string", "description": "Full name for delivery" },
        "phone": { "type": "string", "description": "Contact number" },
        "street": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "country": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "phone", "street", "city", "state", "zip", "country"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the reviewed product" },
        "orderId": { "type": "string", "description": "ID of the order that contained this product" },
        "userId": { "type": "string", "description": "UID of the reviewer" },
        "userName": { "type": "string", "description": "Name of the reviewer" },
        "rating": { "type": "number", "description": "Star rating (1-5)" },
        "comment": { "type": "string", "description": "Review text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was posted" }
      },
      "required": ["productId", "orderId", "userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Global product catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/settings/site": {
      "schema": "SiteSettings",
      "description": "App-wide site configuration"
    },
    "/addresses/{addressId}": {
      "schema": "Address",
      "description": "User shipping addresses"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    }
  }
}
